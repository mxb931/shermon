apiVersion: v1
kind: Secret
metadata:
  name: xstore-monitor-secrets
  namespace: xstore-monitor
type: Opaque
stringData:
  # REQUIRED: Replace with a strong random key before applying.
  # Generate one with: openssl rand -hex 32
  # Copy this file to rancher-secret.yaml, set the value, then apply.
  # Do NOT commit rancher-secret.yaml to git — it is in .gitignore.
  MONITOR_API_KEY: "replace-with-strong-key"
