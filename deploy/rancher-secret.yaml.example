apiVersion: v1
kind: Secret
metadata:
  name: xstore-monitor-secrets
  namespace: xstore-monitor
type: Opaque
stringData:
  # REQUIRED: Replace all values before applying.
  # Generate secrets with: openssl rand -hex 32
  # Copy this file to rancher-secret.yaml, set the values, then apply.
  # Do NOT commit rancher-secret.yaml to git — it is in .gitignore.
  MONITOR_API_KEY: "replace-with-strong-key"
  MYSQL_ROOT_PASSWORD: "replace-with-strong-root-password"
  MYSQL_DATABASE: "xstore_monitor"
  MYSQL_USER: "xstore_monitor"
  MYSQL_PASSWORD: "replace-with-strong-app-password"
  MONITOR_DATABASE_URL: "mysql+pymysql://xstore_monitor:replace-with-strong-app-password@xstore-monitor-db:3306/xstore_monitor?charset=utf8mb4"
